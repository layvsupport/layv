{
  "name": "layv",
  "version": "1.0.0",
  "description": "LAYV - Unified AI Workspace Platform",
  "main": "electron/main.js",
  "author": "BlendBytes",
  "license": "MIT",
  "homepage": "https://github.com/ChanHo-park-01/AISpace",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChanHo-park-01/AISpace.git"
  },
  "keywords": [
    "electron",
    "ai",
    "workspace",
    "productivity",
    "chatgpt",
    "claude",
    "gemini"
  ],
  "scripts": {
    "start": "electron .",
    "smoke": "electron electron/smoke-production.mjs",
    "smoke:claude": "electron electron/smoke-production.mjs https://claude.ai/",
    "pack": "electron-packager . LAYV --platform=win32 --arch=x64 --out=dist --overwrite --icon=assets/icons/icon.ico",
    "pack:all": "electron-packager . LAYV --all --out=dist --overwrite --icon=assets/icons/icon.ico",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.blendbytes.layv",
    "productName": "LAYV",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "image/**/*",
      "index.html",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-packager": "^17.1.2"
  }
}
